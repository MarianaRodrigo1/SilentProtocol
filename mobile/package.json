{
  "name": "silent-protocol-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm run typecheck",
    "build:android": "npm run build:apk:local",
    "build:apk": "eas build -p android --profile preview",
    "build:apk:prod": "eas build -p android --profile production",
    "build:apk:local": "set \"ANDROID_HOME=%LOCALAPPDATA%\\Android\\Sdk\" && set \"ANDROID_SDK_ROOT=%ANDROID_HOME%\" && set \"NODE_ENV=production\" && cd android && .\\gradlew.bat assembleRelease -Dorg.gradle.warning.mode=none",
    "build:apk:fresh": "npm run prebuild:android:safe && npm run build:apk:local",
    "prebuild:android": "npx expo prebuild --platform android --clean",
    "stop:gradle": "cd android 2>nul && .\\gradlew.bat --stop 2>nul || exit 0",
    "prebuild:android:safe": "node scripts/prebuild-android-safe.cjs",
    "prebuild:android:no-clean": "npx expo prebuild --platform android",
    "prebuild:android:after-restart": "node scripts/prebuild-android-after-restart.cjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "expo": "^53.0.0",
    "expo-battery": "~9.1.4",
    "expo-camera": "^16.0.7",
    "expo-contacts": "~14.2.6",
    "expo-device": "~7.1.4",
    "expo-image": "~2.4.1",
    "expo-location": "^18.0.7",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "^2.2.3",
    "expo-task-manager": "~13.1.6",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-ble-plx": "^3.5.1",
    "react-native-safe-area-context": "5.4.0",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "typescript": "~5.8.3"
  }
}
